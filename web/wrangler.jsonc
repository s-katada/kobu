{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kobu-editor",
  "main": "worker/index.ts",
  "compatibility_date": "2026-05-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    { "pattern": "kobu-editor.digletts.dev", "custom_domain": true }
  ]
}
